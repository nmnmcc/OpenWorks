{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["node"],
    "jsx": "preserve",
    "incremental": true,
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "./config.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules"]
}
